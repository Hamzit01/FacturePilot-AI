{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "20.x",
        "includeFiles": [
          "index.html",
          "login.html",
          "register.html",
          "dashboard.html",
          "clients.html",
          "factures.html",
          "relances.html",
          "encours.html",
          "conformite.html",
          "settings.html",
          "cgu.html",
          "confidentialite.html",
          "guide-utilisateur.html",
          "assets/app.css",
          "assets/app.js"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "backend/server.js" }
  ]
}
