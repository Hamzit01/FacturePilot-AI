# ─── FacturePilot AI — Variables d'environnement ─────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Serveur
PORT=3333
NODE_ENV=production                     # development | production

# Origines autorisées (virgule-séparées)
# En développement local, laisser vide ou mettre http://localhost:3333
ALLOWED_ORIGINS=https://votre-domaine.fr,https://www.votre-domaine.fr

# JWT — Générez un secret fort : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_CHAINE_ALEATOIRE_DE_64_CHARS_MINIMUM

# SMTP (Brevo recommandé — gratuit jusqu'à 300 emails/jour)
# Inscription sur https://brevo.com → SMTP & API → Paramètres SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre_email@domaine.com
SMTP_PASS=votre_cle_smtp_brevo
SMTP_FROM=noreply@votre-domaine.fr

# (Optionnel) HTTPS direct — en production, préférez Nginx/Caddy comme reverse proxy
SSL_KEY=
SSL_CERT=
HTTPS_PORT=3443
